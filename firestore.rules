rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only access their own file metadata.
    // Primary access is via the backend (Admin SDK, which bypasses rules),
    // but these rules provide defense-in-depth against direct client access.
    match /users/{userId}/files/{fileId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Workspace layout persistence (window positions, file manager path, etc.)
    // Written directly from the frontend via Firestore JS SDK.
    match /users/{userId}/workspace/{docId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
