# Asisto Frontend Configuration
# Copy this to .env and fill in your values.
# DO NOT commit .env to git -- it's in .gitignore.

# The URL of the deployed FastAPI backend (Cloud Run).
# This is set automatically by Pulumi during deployment.
# For local development, point to your local backend:
#   API_ENDPOINT=http://localhost:8080
API_ENDPOINT=https://asisto-api-xxxxx-uc.a.run.app
